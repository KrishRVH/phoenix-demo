# Intent: ignore generated/local artifacts only. Keep lockfiles, fixtures,
# corpora, examples, Makefiles, and shared editor config visible by default.

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Editor temporary files, not editor project config
*.swp
*.swo
*~
.#*

# Local environment/secrets
.env
.env.*
!.env.example
!.env.sample
!.env.template

# Logs and temporary files
*.log
*.tmp
*.temp
/.tmp/
/tmp/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Dependency directories
node_modules/
/assets/node_modules/
/vendor/

# Generic generated output
/.gstack/
/.cache/
/build/
/coverage/
/dist/
/out/

# JavaScript / TypeScript
*.tsbuildinfo
.eslintcache
/.angular/
/.astro/
/.next/
/.nuxt/
/.nyc_output/
/.parcel-cache/
/.svelte-kit/
/.turbo/
/.vite/

# Python
.coverage
.mypy_cache/
.pytest_cache/
.ruff_cache/
.venv/
__pycache__/
*.egg-info/
/htmlcov/

# mise
mise.local.toml
mise.*.local.toml
.mise.local.toml
.mise.*.local.toml
mise.local.lock
mise.*.local.lock
.mise.local.lock
.mise.*.local.lock

# Dagger module local output
/dagger/.turbo/
/dagger/dist/

# Elixir / Erlang
/_build/
/cover/
/deps/
/doc/
/.elixir_ls/
/.fetch
erl_crash.dump
rebar3.crashdump
*.beam
*.ez
*.plt
*.plt.hash
boring_live-*.tar
/priv/static/assets/
/priv/static/cache_manifest.json

# Haskell
/dist-newstyle/
/.stack-work/
cabal.project.local
cabal.project.local~
.ghc.environment.*
.hpc/
*.hi
*.dyn_hi
*.dyn_o
*.hie
*.hp
*.prof
*.tix
*.eventlog
